{
  "name": "@woodpecker-js/woodpecker",
  "version": "0.1.0",
  "description": "Woodpecker umbrella package — registers all notification services into the core router and re-exports the public API.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@woodpecker-js/core": "workspace:*",
    "@woodpecker-js/bark": "workspace:*",
    "@woodpecker-js/discord": "workspace:*",
    "@woodpecker-js/generic": "workspace:*",
    "@woodpecker-js/googlechat": "workspace:*",
    "@woodpecker-js/gotify": "workspace:*",
    "@woodpecker-js/ifttt": "workspace:*",
    "@woodpecker-js/join": "workspace:*",
    "@woodpecker-js/logger": "workspace:*",
    "@woodpecker-js/matrix": "workspace:*",
    "@woodpecker-js/mattermost": "workspace:*",
    "@woodpecker-js/ntfy": "workspace:*",
    "@woodpecker-js/opsgenie": "workspace:*",
    "@woodpecker-js/pushbullet": "workspace:*",
    "@woodpecker-js/pushover": "workspace:*",
    "@woodpecker-js/rocketchat": "workspace:*",
    "@woodpecker-js/slack": "workspace:*",
    "@woodpecker-js/smtp": "workspace:*",
    "@woodpecker-js/teams": "workspace:*",
    "@woodpecker-js/telegram": "workspace:*",
    "@woodpecker-js/zulip": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "tsdown": "^0.22.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beshkenadze/woodpecker.git",
    "directory": "packages/woodpecker"
  },
  "homepage": "https://github.com/beshkenadze/woodpecker#readme",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
