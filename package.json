{
  "name": "woodpecker",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "check": "biome check",
    "format": "biome check --write",
    "ci": "turbo build typecheck test && biome ci",
    "version": "changeset version",
    "release": "turbo build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "tsdown": "^0.22.3",
    "turbo": "^2.9.18"
  }
}
